<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    tools:context=".VideoCallActivity">

    <!-- 远程视频容器（全屏背景） -->
    <FrameLayout
        android:id="@+id/remote_video_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#2D2D44">

        <!-- 默认占位背景 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#2D2D44" />
    </FrameLayout>

    <!-- 本地视频预览（小窗口，右上角） -->
    <FrameLayout
        android:id="@+id/local_video_container"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="@drawable/rounded_video_frame"
        android:elevation="8dp">

        <!-- 默认占位背景 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#3D3D5C" />
    </FrameLayout>

    <!-- 顶部状态区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#80000000"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 咨询师名字 -->
        <TextView
            android:id="@+id/consultantNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="咨询师"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- 通话状态 -->
        <TextView
            android:id="@+id/status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="正在连接..."
            android:textColor="#CCCCCC"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 振铃动画区域（中间头像） -->
    <LinearLayout
        android:id="@+id/avatarWaitingView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical">

        <!-- 外圈光环1 -->
        <View
            android:id="@+id/avatarRing1"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:alpha="0.7"
            android:background="@drawable/ring_animation"
            android:visibility="gone" />

        <!-- 外圈光环2 -->
        <View
            android:id="@+id/avatarRing2"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginTop="-160dp"
            android:alpha="0.7"
            android:background="@drawable/ring_animation"
            android:visibility="gone" />

        <!-- 头像圆圈 -->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginTop="-100dp"
            android:background="@drawable/avatar_circle">

            <!-- 头像首字母 -->
            <TextView
                android:id="@+id/avatarInitial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="咨"
                android:textColor="@android:color/white"
                android:textSize="48sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- 等待提示 -->
        <TextView
            android:id="@+id/waitingHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="等待对方接听..."
            android:textColor="#AAAAAA"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- 底部控制按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#80000000"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="24dp">

        <!-- 静音按钮 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_mute"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:alpha="1.0"
                android:background="@drawable/circle_button_bg"
                android:contentDescription="静音"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_mic_on" />

            <TextView
                android:id="@+id/mute_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="静音"
                android:textColor="@android:color/white"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 视频开关按钮 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_video"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:alpha="1.0"
                android:background="@drawable/circle_button_bg"
                android:contentDescription="摄像头"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_videocam" />

            <TextView
                android:id="@+id/video_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="关摄像头"
                android:textColor="@android:color/white"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 挂断按钮 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_hangup"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/hangup_button_bg"
                android:contentDescription="挂断"
                android:padding="14dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_call_end" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="挂断"
                android:textColor="@android:color/white"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 返回按钮（左上角） -->
    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:alpha="0.8"
        android:background="@drawable/circle_button_bg"
        android:contentDescription="返回"
        android:padding="10dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_arrow_back" />

</FrameLayout>
